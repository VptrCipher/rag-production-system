# 🔑 RAG Production System - Environment Variables Template
# Copy this file to .env and fill in your values.
# DO NOT COMMIT YOUR REAL .ENV FILE TO VERSION CONTROL.

# --- LLM Provider (OpenAI Recommended) ---
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Groq (Free Fallback) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Retrieval & Reranking ---
# Get a free API key at cohere.com
COHERE_API_KEY=your_cohere_api_key_here
COHERE_RERANK_MODEL=rerank-english-v3.0

# --- Vector Database (Qdrant) ---
# Default for local docker: localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# --- RAG Parameters ---
RETRIEVAL_TOP_K=30
RERANK_TOP_N=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
